# ==== el env variables el hayst3melha el backend ====
# copy el file da le ".env" w 3abbeeh bel values el sa7

# el port elly el server hayshta8al 3aleh
PORT=4000

# el environment (development / production)
NODE_ENV=development

# el mongo connection string
MONGO_URI=mongodb://127.0.0.1:27017/el_moquwal

# el secret bta3 el JWT access token (gheero fel production)
JWT_ACCESS_SECRET=change_me_to_a_very_long_random_string_at_least_64_chars
JWT_ACCESS_EXPIRES=15m

# el secret bta3 el refresh token (mkhtlef 3an el access)
JWT_REFRESH_SECRET=change_me_too_another_very_long_random_string_at_least_64_chars
JWT_REFRESH_EXPIRES=7d

# el origin el masmoo7 lel CORS (el frontend)
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# el cookie domain (seeb-ha fadya fel dev)
COOKIE_DOMAIN=

# trust proxy (e5leeh 1 law wra nginx/cloudflare)
TRUST_PROXY=0

# uploads directory (outside web root)
UPLOADS_DIR=./uploads
UPLOAD_MAX_SIZE_MB=5

# Anthropic API key — for AI price estimation feature
ANTHROPIC_API_KEY=sk-ant-your-key-here

# نقاط المقاول — تقديم العروض (اختياري)
CONTRACTOR_INITIAL_CREDITS=5
BID_CREDIT_COST_DEFAULT=1
BID_CREDIT_COST_ABOVE_1M=5
